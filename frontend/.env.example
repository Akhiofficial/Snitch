# Frontend Environment Variables
# Copy this file to .env.local and fill in your values

# In development, leave this empty — Vite proxy handles /api/* → localhost:3000
# In production (Vercel), set this to your Render backend URL
# e.g. https://snitch-backend.onrender.com
VITE_API_BASE_URL=

# Razorpay public key (safe to expose — it's the public/client-side key)
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx
